  <property name="styleSheet">
   <string notr="true">/* ------------------------------------------- */
/* ---      PROFESSIONAL DARK THEME        --- */
/* ------------------------------------------- */

/* 1. MAIN WINDOW &amp; GLOBAL DEFAULTS
   Changed the background-color here to your requested shade.
---------------------------------------------- */
QMainWindow, QWidget {
    background-color: #231f20; /* YOUR NEW, VERY DARK BACKGROUND */
    color: #E0E0E0;
    font-family: Segoe UI;
      border-radius: 12px;

}

/* 2. VIEW PANELS &amp; SEPARATOR LINES
---------------------------------------------- */
#img, #img_2, #panaroma {
    background-color: #353535;   /* This is now the lighter grey for panels */
    border: 1px solid #1E1E1E;
    border-top-color: #4A4A4A;
    border-radius: 2px;
}

QFrame {
    background-color: #2D2D2D;
}

/* 3. INTERACTIVE WIDGETS
---------------------------------------------- */
/* Push Buttons */
#pushButton_capture_button_2, #pushButton_capture_button, #stitch_button, #calibrate_button, #dlt, #dlt2, #load_img, #load_img_2 {
    background-color: #555555;
    border: 1px solid #444444;
    padding: 5px;
    border-radius: 2px;
    min-height: 20px;
}
/* CORRECTED: The space before the colon was removed for all states */
#pushButton_capture_button_2:hover, #pushButton_capture_button:hover,  #stitch_button:hover, #calibrate_button:hover, #dlt2:hover, #dlt:hover, #load_img:hover, #load_img_2:hover, #pushButton_save_panorama:hover, #pushButton_delete_panorama:hover{
    background-color: #666666; /* A standard hover highlight */
}
#pushButton_capture_button_2:pressed, #pushButton_capture_button:pressed,  #stitch_button:pressed, #calibrate_button:pressed, #dlt2:pressed, #dlt:pressed, #load_img:pressed, #load_img_2:pressed, #pushButton_save_panorama:pressed, #pushButton_delete_panorama:pressed {
    background-color: #4A4A4A;
}
#calibrate:disabled, #delete_2:disabled, #delete_3:disabled, #load_img:disabled, #load_img2:disabled {
    background-color: #404040;
    color: #6A6A6A;
    border-color: #505050;
}

/* Text Inputs */
QLineEdit, QPlainTextEdit, QTextEdit {
    background-color: #2D2D2D;
    border: 1px solid #555555;
    padding: 4px;
    border-radius: 2px;
}

/* 4. TEXT &amp; LABELS
---------------------------------------------- */
QLabel {
    background-color: transparent;
    color: #F0F0F0;
    padding-left: 5px;
}
QLabel#titleLabel {
    color: #FFFFFF;
    font-weight: bold;
}

/* 5. DATA &amp; DISPLAY WIDGETS
---------------------------------------------- */
/* Table Widgets */
QTableWidget {
    background-color: #2D2D2D;
    gridline-color: #454545;
}
QHeaderView::section {
    background-color: #454545;
    padding: 4px;
    border: 1px solid #555555;
}

/* Progress Bar */
#progressbar {
    border: 1px solid #555555;
    border-radius: 2px;
    text-align: center;
    background-color: #2D2D2D;
    color: #FFFFFF;
}
#progressbar::chunk {
    background-color: #0078d7;
    width: 20px;
}

/* 6. SCROLLBARS (VERTICAL &amp; HORIZONTAL)
---------------------------------------------- */
QScrollBar:vertical {
    border: none;
    background: #1B1B1E; /* Match new background */
    width: 12px;
    margin: 15px 0 15px 0;
}
QScrollBar:handle:vertical {
    background: #5A5A5A;
    min-height: 30px;
    border-radius: 6px;
}
QScrollBar:handle:vertical:hover {
    background: #6A6A6A;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: #454545;
    height: 14px;
    subcontrol-origin: margin;
}

QScrollBar:horizontal {
    border: none;
    background: #1B1B1E; /* Match new background */
    height: 12px;
    margin: 0px 15px 0px 15px;
}
QScrollBar::handle:horizontal {
    background: #5A5A5A;
    min-width: 30px;
    border-radius: 6px;
}
QScrollBar::handle:horizontal:hover {
    background: #6A6A6A;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: #454545;
    width: 14px;
    subcontrol-origin: margin;
}</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">QToolButton {
  background-color: transparent;
  color: #F0F0F0;
  border-radius: 4px;
  margin: 0px;
  padding: 2px;
}

QToolButton:checked {
  margin: 1px;
  background-color: transparent;
  border: 1px solid #FFE723;
}

QToolButton:checked:disabled {
  border: 1px solid #CFBB1C;
}

QToolButton:pressed {
   margin: 1px;
   border: 1px solid #FFE723;
}

QToolButton:disabled {
	color: #6e6e6e;
	background-color: #444444;
	border: 2px solid #444444;
}

QToolButton:disabled:hover {
  border: 1px solid #32414B;
}

QToolButton:hover {
 background-color: #21252B;
}

QFrame {
 background-color: rgb(27, 29, 35);
}

QLabel#label_bad{
	background-color: Red;
	border-radius: 6px;
}

QLabel#label_good{
	background-color: Green;
	border-radius: 6px;
}
</string>
